{
  "name": "Chargate",
  "description": "Security + lint gate for pull requests — Trivy, Semgrep, Checkov, ShellCheck and more, reported as a Check Run. Install once; every repo is scanned with no workflow file.",
  "url": "https://github.com/magmamoose/chargate",
  "public": false,
  "hook_attributes": {
    "url": "https://REPLACE-WITH-YOUR-BACKEND/api/v1/webhooks/github",
    "active": true
  },
  "callback_urls": ["https://REPLACE-WITH-YOUR-BACKEND/api/v1/auth/callback"],
  "request_oauth_on_install": false,
  "default_permissions": {
    "checks": "write",
    "contents": "read",
    "pull_requests": "read",
    "metadata": "read"
  },
  "default_events": [
    "pull_request",
    "check_run",
    "installation",
    "installation_repositories"
  ]
}
