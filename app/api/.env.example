# Copy to .env for local dev (compose reads these as CHARGATE_* env vars).
CHARGATE_DATABASE_URL=postgresql+asyncpg://chargate:chargate@db:5432/chargate
CHARGATE_ENVIRONMENT=development

# GitHub App (https://github.com/settings/apps)
CHARGATE_GITHUB_APP_ID=
CHARGATE_GITHUB_APP_PRIVATE_KEY=
CHARGATE_GITHUB_WEBHOOK_SECRET=
CHARGATE_ENGINE_REPO=magmamoose/chargate

# GitHub OAuth (the same App's client id/secret, or a separate OAuth app)
CHARGATE_GITHUB_OAUTH_CLIENT_ID=
CHARGATE_GITHUB_OAUTH_CLIENT_SECRET=

# URLs
CHARGATE_PUBLIC_BASE_URL=http://localhost:8000
CHARGATE_WEB_BASE_URL=http://localhost:5173
CHARGATE_CORS_ORIGINS=["http://localhost:5173"]

# Secrets — generate strong random values for anything but local dev.
CHARGATE_SESSION_SECRET=dev-only-change-me
CHARGATE_INGEST_SECRET=dev-only-change-me

# Policy: false = advisory (neutral check on findings); true = fail on crit/high.
CHARGATE_DEFAULT_BLOCKING=false
